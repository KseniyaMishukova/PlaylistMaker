<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="CreatePlaylistHintAppearance" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="CreatePlaylistTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/create_playlist_input_border</item>
        <item name="hintTextColor">#FFFFFF</item>
        <item name="hintTextAppearance">@style/CreatePlaylistHintAppearance</item>
    </style>

    <style name="CreatePlaylistInput">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textColorHint">#FFFFFF</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
    </style>
    <style name="some_id">
        <item name="android:textSize">19sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
    </style>

    <style name="ys_medium_1">
        <item name="android:textSize">19sp</item>
        <item name="android:textColor">@color/historyTitle</item>
    </style>

    <style name="label">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">16sp</item>
        <item name="android:textColor">@color/historyButtonText</item>
        <item name="android:includeFontPadding">false</item>
    </style>
</resources>